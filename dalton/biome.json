{
	"formatter": {
		"enabled": true,
		"indentStyle": "tab",
		"indentWidth": 2
	},
	"linter": {
		"enabled": true,
		"rules": {
			"recommended": true,
			"suspicious": {
				"noConsole": "off"
			}
		}
	},
	"files": {
		"includes": ["src/**/*.ts", "scripts/**/*.ts"]
	},
	"overrides": [
		{
			"includes": ["src/types-data.ts"],
			"linter": {
				"rules": {
					"suspicious": {
						"noTemplateCurlyInString": "off"
					}
				}
			}
		}
	]
}
